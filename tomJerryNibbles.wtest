import tomJerryNibbles.*

describe "Grupo de pruebas Tom, Jerry y otros" {

  test "Al inicio, la velocidad máxima de Tom es 10 " {
    assert.equals(10, tom.velocidadMaxima())
  }

  test "Si corre 24 metros, (su energía es 90)" {
    tom.correr(24)
    assert.equals (6.2, tom.velocidadMaxima())
  }

  test "test 4" {
    assert.notThat(false)
  }

}